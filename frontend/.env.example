# Required for any build (web + Capacitor). Vite bakes VITE_* in at `npm run build`.
# Copy this file to `frontend/.env` and set your real anon key from Supabase → Settings → API.
VITE_SUPABASE_URL=https://tiavhmbpplerffdjmodw.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional: Razorpay checkout (public Key ID only).
VITE_RAZORPAY_KEY_ID=

# Optional: local API during dev.
# VITE_API_URL=http://localhost:3001/api

# Optional: Firebase (only if you initialize Firebase in the app).
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Set to false to disable [StayHardyAuth] debug logs (when unset, traces are enabled).
VITE_AUTH_TRACE=false

# Never prefix server secrets with VITE_ — they would be embedded in the client bundle.
# RAZORPAY_KEY_SECRET=           # Edge Functions / backend only
# SUPABASE_SERVICE_ROLE_KEY=    # Edge Functions / backend only
