# Copy to keystore.properties and fill in. Do not commit keystore.properties.
# Generate a keystore: keytool -genkeypair -v -keystore stayhardy-release.keystore -alias stayhardy -keyalg RSA -keysize 2048 -validity 10000
storeFile=stayhardy-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=stayhardy
